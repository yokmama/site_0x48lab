generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Media Files ───────────────────────────────────────────────

model MediaFile {
  id          Int          @id @default(autoincrement())
  filename    String
  mime        String
  size        Int
  data        Bytes
  createdAt   DateTime     @default(now())
  teamMembers TeamMember[]
}

// ── Auth ──────────────────────────────────────────────────────

model AdminUser {
  id           Int            @id @default(autoincrement())
  email        String         @unique
  name         String
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id        String    @id
  userId    Int
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ── Blog Posts ─────────────────────────────────────────────────

model BlogPost {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  category  String
  title     String
  excerpt   String   @db.Text
  date      DateTime
  readCount Int      @default(0)
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([published, date])
}

// ── Works / Case Studies ───────────────────────────────────────

model Work {
  id            Int      @id @default(autoincrement())
  slug          String   @unique
  industry      String
  service       String
  title         String
  summary       String   @db.Text
  challenge     String   @db.Text
  solution      String   @db.Text
  tech          String[]
  beforePeriod  String
  beforeQuality String
  afterPeriod   String
  afterQuality  String
  impact        String
  link          String?
  published     Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([industry])
  @@index([service])
  @@index([published, sortOrder])
}

// ── AI Dev Page Content ────────────────────────────────────────

model AiDevProblem {
  id        Int      @id @default(autoincrement())
  title     String
  desc      String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiDevSolution {
  id        Int      @id @default(autoincrement())
  num       String
  title     String
  desc      String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiDevComparisonRow {
  id          Int      @id @default(autoincrement())
  item        String
  traditional String
  ours        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AiDevServicePackage {
  id        Int      @id @default(autoincrement())
  title     String
  delivery  String
  items     String[]
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiDevExampleProject {
  id        Int      @id @default(autoincrement())
  industry  String
  title     String
  delivery  String
  quality   String
  desc      String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiDevProcessStep {
  id        Int      @id @default(autoincrement())
  num       String
  title     String
  desc      String   @db.Text
  badge     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AiDevFaqItem {
  id        Int      @id @default(autoincrement())
  q         String
  a         String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── LP Page Content ────────────────────────────────────────────

model LpProblem {
  id        Int      @id @default(autoincrement())
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LpSolution {
  id        Int      @id @default(autoincrement())
  num       String
  title     String
  desc      String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LpComparisonRow {
  id          Int      @id @default(autoincrement())
  item        String
  traditional String
  ours        String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LpPricing {
  id        Int      @id @default(autoincrement())
  title     String
  price     String
  fromPrice Boolean  @default(true)
  items     String[]
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LpResult {
  id           Int      @id @default(autoincrement())
  industry     String
  title        String
  beforeCost   String
  beforePeriod String
  afterCost    String
  afterPeriod  String
  saving       String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LpFaqItem {
  id        Int      @id @default(autoincrement())
  q         String
  a         String   @db.Text
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Careers ────────────────────────────────────────────────────

model JobOpening {
  id        String   @id
  title     String
  type      String
  location  String
  tags      String[]
  desc      String   @db.Text
  published Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, sortOrder])
}

model TeamMember {
  id          Int        @id @default(autoincrement())
  name        String
  role        String
  photo       String?
  photoFile   MediaFile? @relation(fields: [photoFileId], references: [id])
  photoFileId Int?
  initials    String?
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}
